  <Tasks>
    <CompositionalMultiphaseStatistics
      name="compflowStatistics"
      flowSolverName="compositionalMultiphaseFlow"
      logLevel="1"
      computeCFLNumbers="1"
      computeRegionStatistics="1" />
  </Tasks>

  <Outputs>
